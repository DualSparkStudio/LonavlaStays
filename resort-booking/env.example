# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Payment: local demo test mode (no Razorpay account needed) ───────────
# Simulates checkout on localhost. Never set true on production/Netlify.
VITE_PAYMENT_DEMO_MODE=true
PAYMENT_DEMO_MODE=true

# ─── Payment: Razorpay TEST mode (real test checkout UI) ───────────────────
# Get keys from https://dashboard.razorpay.com/app/keys → switch to Test Mode
# Keys must start with rzp_test_
# When using real test keys, set both demo flags above to false.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret

# Razorpay test card: 4111 1111 1111 1111 · any future expiry · any CVV

# App Configuration
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=The Lonavala Stays

# Email Service (Optional - for production)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=stay@lonavalastays.com

# Admin Configuration
ADMIN_EMAIL=admin@lonavalastays.com
